{
  "name": "backend",
  "version": "1.0.0",
  "description": "TechHaven Store Backend using NestJS and PostgreSQL",
  "author": "Rahul Kumar",
  "license": "MIT",
  "scripts": {
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "start:auto": "node start-server.js",
    "test:api": "node test-api.js",
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "test:integration": "jest --config ./test/jest-integration.json --runInBand",
    "test:prepare-db": "ts-node -r tsconfig-paths/register src/scripts/prepare-test-db.ts",
    "migration:run": "npm run build && npx typeorm migration:run -d dist/config/data-source.js",
    "migration:generate": "npx typeorm migration:generate -d src/config/data-source.ts",
    "migration:create": "npx typeorm migration:create",
    "migration:revert": "npx typeorm migration:revert -d dist/config/database.config.js",
    "seed": "ts-node -r tsconfig-paths/register src/seeds/seed.ts",
    "db:bootstrap": "ts-node -r tsconfig-paths/register src/scripts/bootstrap-db.ts"
  },
  "dependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^10.0.0",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/swagger": "^7.4.2",
    "@nestjs/typeorm": "^10.0.0",
    "@types/multer": "^2.0.0",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "dotenv": "^16.4.5",
    "get-port": "^7.1.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.11.5",
    "razorpay": "^2.9.6",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0",
    "stripe": "^18.5.0",
    "typeorm": "^0.3.20"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^4.17.23",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.11.30",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "jest": "^29.7.0",
    "prettier": "^3.2.5",
    "source-map-support": "^0.5.21",
    "supertest": "^6.3.4",
    "ts-jest": "^29.1.2",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  }
}
